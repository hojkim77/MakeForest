generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String    @id @default(uuid())
  provider     String
  providerId   String
  nickname     String
  avatarUrl    String?
  dongCode     String?
  regionCode   String?
  todosPublic  Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions          FocusSession[]
  wateringLogs      WateringLog[]
  dailySessions     DailySession[]
  pushSubscriptions PushSubscription[]
  userCreatures     UserCreature[]
  fossils           Fossil[]

  @@unique([provider, providerId])
  @@index([dongCode])
  @@index([regionCode])
}

model FocusSession {
  id          String        @id @default(uuid())
  userId      String
  dongCode    String
  startedAt   DateTime      @default(now())
  endedAt     DateTime?
  durationSec Int
  todos       Json          @default("[]")
  status      SessionStatus @default(RUNNING)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([dongCode])
  @@index([status])
}

// 자정 cron이 UserCreature를 박제하여 생성하는 영구 기록
model Fossil {
  id           String   @id @default(uuid())
  userId       String
  dongCode     String
  date         String   // KST "YYYY-MM-DD"
  creatureType String
  stage        Int      // 최종 진화 단계
  fossilX      Int
  fossilY      Int
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([dongCode])
}

model Dong {
  code        String  @id
  name        String
  sigunguCode String
  sidoCode    String
  lat         Float
  lng         Float

  @@index([sigunguCode])
  @@index([sidoCode])
}

// 유저별 영구 생명체 (하루 최대 12회 물주기, 누적 성장)
model UserCreature {
  id         String   @id @default(uuid())
  userId     String   @unique
  stage      Int      @default(0) // 0~9, 누적 waterCount 기반 자동 계산
  waterCount Int      @default(0) // 생애 누적 물주기 횟수
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// 유저별 날짜별 물주기 이력
model WateringLog {
  id        String   @id @default(uuid())
  userId    String
  dongCode  String
  date      String   // KST "YYYY-MM-DD"
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([dongCode, date])
}

// 유저별 날짜별 집중 시간 + 물주기 횟수 집계
model DailySession {
  id         String @id @default(uuid())
  userId     String
  date       String // KST "YYYY-MM-DD"
  elapsedSec Int    @default(0)
  waterCount Int    @default(0) // 오늘 내가 준 물 (최대 3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum SessionStatus {
  RUNNING
  PAUSED
  COMPLETED
  ABANDONED
}
