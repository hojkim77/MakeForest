generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String    @id @default(uuid())
  provider     String
  providerId   String
  nickname     String
  avatarUrl    String?
  dongCode     String?
  todosPublic  Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions      FocusSession[]
  forestObjects ForestObject[]
  wateringLogs  WateringLog[]
  dailySessions DailySession[]

  @@unique([provider, providerId])
  @@index([dongCode])
}

model FocusSession {
  id          String        @id @default(uuid())
  userId      String
  dongCode    String
  startedAt   DateTime      @default(now())
  endedAt     DateTime?
  durationSec Int
  actualSec   Int?
  todos       Json          @default("[]")
  status      SessionStatus @default(RUNNING)

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  forestObject ForestObject?

  @@index([userId])
  @@index([dongCode])
  @@index([status])
}

model ForestObject {
  id           String      @id @default(uuid())
  userId       String
  sessionId    String      @unique
  dongCode     String
  forestX      Int
  forestY      Int
  creatureType String
  harvestedAt  DateTime    @default(now())
  date         String

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  session FocusSession @relation(fields: [sessionId], references: [id])

  @@index([dongCode])
  @@index([dongCode, date])
  @@index([userId])
}

model Dong {
  code        String  @id
  name        String
  sigunguCode String
  sidoCode    String
  lat         Float
  lng         Float

  @@index([sigunguCode])
  @@index([sidoCode])
}

// 날짜별 동네별 오늘의 생명체
model Creature {
  id         String   @id @default(uuid())
  dongCode   String
  date       String   // KST "YYYY-MM-DD"
  stage      Int      @default(0) // 0=씨앗 1=새싹 2=나무1 3=나무2 4=나무3
  waterCount Int      @default(0) // 동네 전체 누적 물주기 수
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([dongCode, date])
  @@index([dongCode])
}

// 유저별 날짜별 물주기 이력
model WateringLog {
  id        String   @id @default(uuid())
  userId    String
  dongCode  String
  date      String   // KST "YYYY-MM-DD"
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([dongCode, date])
}

// 유저별 날짜별 집중 시간 + 물주기 횟수 집계
model DailySession {
  id         String @id @default(uuid())
  userId     String
  date       String // KST "YYYY-MM-DD"
  elapsedSec Int    @default(0)
  waterCount Int    @default(0) // 오늘 내가 준 물 (최대 3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

enum SessionStatus {
  RUNNING
  PAUSED
  COMPLETED
  HARVESTED
  ABANDONED
}
