generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String    @id @default(uuid())
  provider     String
  providerId   String
  nickname     String
  avatarUrl    String?
  dongCode     String?
  regionCode   String?
  todosPublic  Boolean   @default(true)
  points       Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions           FocusSession[]
  wateringLogs       WateringLog[]
  pushSubscriptions  PushSubscription[]
  userCreatures      UserCreature[]
  communityPosts     CommunityPost[]
  communityReactions CommunityReaction[]
  communityComments  CommunityComment[]
  userGuideState     UserGuideState?

  sentFriendRequests     Friendship[]  @relation("FriendshipRequester")
  receivedFriendRequests Friendship[]  @relation("FriendshipAddressee")
  sentPokes              Poke[]        @relation("PokeFromUser")
  receivedPokes          Poke[]        @relation("PokeToUser")

  @@unique([provider, providerId])
  @@index([dongCode])
  @@index([regionCode])
}

model FocusSession {
  id              String        @id @default(uuid())
  userId          String
  dongCode        String
  date            String        // KST "YYYY-MM-DD"
  startedAt       DateTime      @default(now())
  createdAt       DateTime      @default(now())
  totalElapsedSec Int           @default(0) // 완료된 사이클 누적 집중 시간 (waterCount * 1800)
  waterCount      Int           @default(0) // 오늘 물주기 횟수 (최대 12)
  todos           Json          @default("[]")
  status          SessionStatus @default(RUNNING)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([dongCode])
  @@index([date])
  @@index([status])
}

model Dong {
  code        String  @id
  name        String
  sigunguCode String
  sidoCode    String
  lat         Float
  lng         Float

  @@index([sigunguCode])
  @@index([sidoCode])
}

// 유저별 영구 생명체 (하루 최대 12회 물주기, 누적 성장)
model UserCreature {
  id         String   @id @default(uuid())
  userId     String   @unique
  stage           Int      @default(0) // 0~9, 누적 totalWaterCount 기반 자동 계산
  totalWaterCount Int      @default(0) // 생애 누적 물주기 횟수
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// 유저별 날짜별 물주기 이력
model WateringLog {
  id        String   @id @default(uuid())
  userId    String
  dongCode  String
  date      String   // KST "YYYY-MM-DD"
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([dongCode, date])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// 지역 공동 채집 미션 — lazy 생성, 세션 시작으로 currentCount 증가
model DailyCollection {
  id           String    @id @default(uuid())
  regionCode   String
  date         String    // KST "YYYY-MM-DD"
  creatureType String    // CREATURE_TYPES 14종 중 1종
  targetCount  Int       // 활성 유저 수 기반 목표 (max(4, round(activeUsers * 3)))
  currentCount Int       @default(0)
  isCompleted  Boolean   @default(false)
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  @@unique([regionCode, date])
  @@index([regionCode, date])
}

// 커뮤니티 피드 — 세션 첫 시작 시 자동 생성
model CommunityPost {
  id        String   @id @default(uuid())
  userId    String
  sessionId String   @unique
  date      String   // KST "YYYY-MM-DD"
  dongName   String?
  regionCode String?
  createdAt  DateTime @default(now())

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions CommunityReaction[]
  comments  CommunityComment[]

  @@unique([userId, date])
  @@index([createdAt])
  @@index([date])
  @@index([regionCode])
}

model CommunityReaction {
  id     String @id @default(uuid())
  postId String
  userId String
  emoji  String // "🔥" | "💪" | "👏"

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, emoji])
  @@index([postId])
}

model CommunityComment {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model UserGuideState {
  id                       String    @id @default(uuid())
  userId                   String    @unique
  tourCompletedAt          DateTime?
  lastDailyGuideShownDate  String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum SessionStatus {
  RUNNING
  PAUSED
  COMPLETED
  ABANDONED
  IDLE
}

model Friendship {
  id          String           @id @default(uuid())
  requesterId String
  addresseeId String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  acceptedAt  DateTime?

  requester User @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@index([requesterId, status])
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
}

model Poke {
  id         String    @id @default(uuid())
  fromUserId String
  toUserId   String
  createdAt  DateTime  @default(now())
  readAt     DateTime?

  fromUser User @relation("PokeFromUser", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("PokeToUser",   fields: [toUserId],   references: [id], onDelete: Cascade)

  @@index([toUserId, createdAt(sort: Desc)])
  @@index([toUserId, readAt])
  @@index([fromUserId, toUserId, createdAt])
}
