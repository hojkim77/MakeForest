{
  "name": "@makeforest/server",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "jest --no-coverage",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "migrate:dong-codes": "tsx --env-file=.env src/scripts/migrateDongCodes.ts"
  },
  "dependencies": {
    "@makeforest/db": "*",
    "@makeforest/redis": "*",
    "@makeforest/types": "*",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/node-cron": "^3.0.11",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
