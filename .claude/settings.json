{
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(find . *)",
      "Bash(find /Users/skylar/Desktop/MakeForest*)",
      "Bash(grep*)",
      "Bash(yarn lint*)",
      "Bash(yarn type-check*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/skylar/Desktop/MakeForest && yarn lint --silent 2>&1 | grep -v '^$' | head -10"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/skylar/Desktop/MakeForest/.claude/hooks/notify-spec-written.sh",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/skylar/Desktop/MakeForest && yarn type-check 2>&1 | grep -E 'error TS' | head -20"
          }
        ]
      }
    ]
  }
}
